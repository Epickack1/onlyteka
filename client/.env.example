# client/.env.example
# Публичный VAPID-ключ — должен совпадать с server/.env
VITE_VAPID_PUBLIC_KEY=ваш_публичный_VAPID_ключ

# Куда Vite-dev проксирует /api и /socket.io.
# По умолчанию: http://127.0.0.1:3000. Используйте https://… если сервер
# поднят с локальным TLS-сертификатом (server/certs/).
# VITE_API_TARGET=http://127.0.0.1:3000
