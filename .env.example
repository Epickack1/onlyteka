# .env.example
# Шаблон переменных окружения для docker compose up.
# Скопируйте: cp .env.example .env  и заполните реальными значениями.

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=замените_на_длинную_случайную_строку_не_менее_32_символов
JWT_REFRESH_SECRET=другая_длинная_случайная_строка_не_менее_32_символов
ACCESS_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ─── Сид первого администратора ────────────────────────────────
# Создаётся автоматически при первом старте, если SEED_ENABLED=true
SEED_ENABLED=true
SEED_ADMIN_EMAIL=admin@onlyteka.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# ─── RabbitMQ (практика 27) ────────────────────────────────────
# Управляющая консоль: http://localhost:15672 (guest/guest)
RABBIT_URL=amqp://rabbitmq:5672

# ─── VAPID-ключи для Web Push ──────────────────────────────────
# Сгенерировать пару: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=ваш_публичный_VAPID_ключ
VAPID_PRIVATE_KEY=ваш_приватный_VAPID_ключ
VAPID_SUBJECT=mailto:admin@onlyteka.local
