# server/.env.example
# Используется при локальном запуске сервера БЕЗ docker compose (npm run dev).
# При запуске через docker compose все переменные берутся из корневого .env.

PORT=3000

# Postgres (локально — на хосте, в Docker — через сервис postgres)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=onlyteka
PG_USER=postgres
PG_PASSWORD=postgres

# Mongo (отзывы)
MONGO_URL=mongodb://localhost:27017/onlyteka

# Redis (кэш)
REDIS_URL=redis://127.0.0.1:6379

# RabbitMQ (П27) — очередь уведомлений
RABBIT_URL=amqp://localhost:5672

# JWT
JWT_ACCESS_SECRET=замените_на_длинную_случайную_строку
JWT_REFRESH_SECRET=другая_длинная_случайная_строка
ACCESS_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Сид администратора при первом запуске
SEED_ENABLED=true
SEED_ADMIN_EMAIL=admin@onlyteka.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# Клиент (для CORS, если потребуется явно)
CLIENT_URL=http://localhost:5173

# VAPID для Web Push (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@onlyteka.local
